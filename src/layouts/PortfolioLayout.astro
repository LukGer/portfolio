---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lukas Gerhold",
  description = "Lukas Gerhold — developer, designer. Portfolio and contact.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="bg-bg font-sans text-sm leading-[1.55] text-ink antialiased [font-feature-settings:'liga'_1,'calt'_1]"
  >
    <slot />
  </body>
</html>
