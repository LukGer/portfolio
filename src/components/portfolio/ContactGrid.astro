---
import type { ContactEntry } from "@/data/portfolio";

interface Props {
  entries: ContactEntry[];
}

const { entries } = Astro.props;
---

{
  entries.map((entry) => (
    <a
      class="portfolio-contact-link text-inherit no-underline"
      href={entry.kind === "email" ? `mailto:${entry.email}` : entry.href}
      target={entry.kind === "link" ? "_blank" : undefined}
      rel={entry.kind === "link" ? "noopener noreferrer" : undefined}
    >
      <div class="mb-1 text-[11px] tracking-wide text-muted">
        {entry.label}
      </div>
      <div class="text-sm font-bold">
        {entry.kind === "email" ? entry.email : entry.line}
      </div>
    </a>
  ))
}
