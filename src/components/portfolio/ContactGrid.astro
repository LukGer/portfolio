---
import { ScrambleEmailLink } from "@/components/portfolio/ScrambleEmailLink.tsx";
import type { ContactEntry } from "@/data/portfolio";

interface Props {
  entries: ContactEntry[];
}

const { entries } = Astro.props;
---

{
  entries.map((entry) =>
    entry.kind === "email" ? (
      <ScrambleEmailLink client:load email={entry.email} label={entry.label} />
    ) : (
      <a
        class="portfolio-contact-link text-inherit no-underline"
        href={entry.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="mb-1 text-[11px] tracking-wide text-muted">
          {entry.label}
        </div>
        <div class="text-sm font-bold">{entry.line}</div>
      </a>
    ),
  )
}
