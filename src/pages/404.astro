---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";

---

<PortfolioLayout title="404 — Lukas Gerhold" description="Page not found.">
	<div
		class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 py-12 text-center font-sans text-ink"
	>
		<div class="text-[11px] tracking-[0.1em] text-muted tabular-nums">404</div>
		<h1 class="text-sm font-bold tracking-wide">NOT FOUND</h1>
		<p class="max-w-[320px] text-[13px] leading-relaxed text-ink-secondary">
			This path does not exist. Try the index instead.
		</p>
		<a
			class="mt-2 border-b border-lime pb-0.5 text-xs text-lime no-underline transition-opacity hover:opacity-80"
			href="/">← BACK HOME</a
		>
	</div>
</PortfolioLayout>
